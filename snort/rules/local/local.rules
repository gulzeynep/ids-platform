# Local fallback signatures derived from official Snort web categories.
# These are deliberately raw-payload rules so the lab keeps alerting even if
# HTTP service classification is delayed or incomplete inside Docker.

alert tcp any any -> any 80 ( msg:"Sensor: HTTP Flow Candidate"; flags:S; metadata:ruleset local-sensor-heartbeat; classtype:misc-activity; sid:9900003; rev:1; )
alert tcp any any -> any any ( msg:"Critical: Shadow File Access"; flow:stateless; pkt_data; content:"/etc/shadow",fast_pattern,nocase; metadata:ruleset local-official-fallback, official_category server-webapp; classtype:attempted-recon; sid:9901129; rev:5; )
alert tcp any any -> any any ( msg:"High: Password File Disclosure Attempt"; flow:stateless; pkt_data; content:"/etc/passwd",fast_pattern,nocase; metadata:ruleset local-official-fallback, official_category server-webapp; classtype:attempted-recon; sid:9901122; rev:5; )
alert tcp any any -> any any ( msg:"High: Acunetix Scanner Probe"; flow:stateless; pkt_data; content:"/acunetix-wvs-test-for-some-inexistent-file",fast_pattern,nocase; metadata:ruleset local-official-fallback, official_category app-detect; classtype:web-application-attack; sid:99025359; rev:5; )
alert tcp any any -> any any ( msg:"Critical: SQL Union Select Injection"; flow:stateless; pkt_data; content:"union",fast_pattern,nocase; content:"select",nocase; pcre:"/union\s+(all\s+)?select\s+/i"; metadata:ruleset local-official-fallback, official_category sql; classtype:web-application-attack; sid:99013990; rev:5; )
alert tcp any any -> any any ( msg:"High: Script Tag XSS Attempt"; flow:stateless; pkt_data; content:"<script",fast_pattern,nocase; metadata:ruleset local-official-fallback, official_category server-webapp; classtype:web-application-attack; sid:99007070; rev:5; )
alert tcp any any -> any any ( msg:"High: Environment File Disclosure"; flow:stateless; pkt_data; content:".env",fast_pattern,nocase; metadata:ruleset local-official-fallback, official_category server-webapp; classtype:web-application-attack; sid:9901126; rev:5; )
alert tcp any any -> any any ( msg:"High: WordPress Config Disclosure"; flow:stateless; pkt_data; content:"wp-config.php",fast_pattern,nocase; metadata:ruleset local-official-fallback, official_category server-webapp; classtype:web-application-attack; sid:9901127; rev:5; )
alert tcp any any -> any any ( msg:"Medium: phpMyAdmin Probe"; flow:stateless; pkt_data; content:"phpmyadmin",fast_pattern,nocase; metadata:ruleset local-official-fallback, official_category server-webapp; classtype:web-application-attack; sid:9901128; rev:5; )
alert tcp any any -> any any ( msg:"Critical: Log4Shell JNDI Lookup"; flow:stateless; pkt_data; content:"${jndi:",fast_pattern,nocase; metadata:ruleset local-official-fallback, official_category server-webapp; classtype:web-application-attack; sid:99044228; rev:5; )

# 2026 web CVE demo signatures. These are safe IDS lab triggers that model
# observable request patterns without requiring a vulnerable application.
alert tcp any any -> any $HTTP_PORTS ( msg:"Critical: CVE-2026-24880 Apache Tomcat request smuggling probe"; flow:to_server,established; http_header; content:"Transfer-Encoding|3A| chunked",nocase; content:";",distance 0,within 80; metadata:ruleset local-2026-cve, cve CVE-2026-24880; service:http; classtype:web-application-attack; sid:992624880; rev:1; )
alert tcp any any -> any $HTTP_PORTS ( msg:"High: CVE-2026-29046 TinyWeb header injection probe"; flow:to_server,established; http_header; content:"%0d%0a",fast_pattern,nocase; metadata:ruleset local-2026-cve, cve CVE-2026-29046; service:http; classtype:web-application-attack; sid:992629046; rev:1; )
alert tcp any any -> any $HTTP_PORTS ( msg:"Critical: CVE-2026-1492 WordPress admin registration abuse probe"; flow:to_server,established; http_uri; content:"/wp-admin/admin-ajax.php",fast_pattern,nocase; http_client_body; content:"administrator",nocase; content:"action=",nocase; metadata:ruleset local-2026-cve, cve CVE-2026-1492; service:http; classtype:web-application-attack; sid:992601492; rev:1; )
alert tcp any any -> any $HTTP_PORTS ( msg:"Critical: CVE-2026-24880 Apache Tomcat request smuggling demo marker"; flow:to_server,established; http_uri; content:"/cve-2026-24880",fast_pattern,nocase; metadata:ruleset local-2026-cve-demo, cve CVE-2026-24880; service:http; classtype:web-application-attack; sid:992624881; rev:1; )
alert tcp any any -> any $HTTP_PORTS ( msg:"High: CVE-2026-29046 TinyWeb encoded header injection demo marker"; flow:to_server,established; http_raw_uri; content:"/cve-2026-29046",fast_pattern,nocase; content:"%0d%0a",nocase; metadata:ruleset local-2026-cve-demo, cve CVE-2026-29046; service:http; classtype:web-application-attack; sid:992629047; rev:1; )
