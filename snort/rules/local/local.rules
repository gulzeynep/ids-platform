# Local fallback signatures derived from enabled official Snort web categories.
# Official rules remain loaded first. These local SIDs mirror common official
# web-app detections so the lab dashboard still receives alerts if a ruleset
# revision or policy state stops an official SID from matching.

alert tcp $EXTERNAL_NET any -> $HOME_NET $HTTP_PORTS ( msg:"LOCAL-OFFICIAL-WEBAPP /etc/passwd file access attempt"; flow:to_server,established; http_uri; content:"/etc/passwd",fast_pattern,nocase; metadata:ruleset local-official-fallback; service:http; classtype:attempted-recon; sid:9901122; rev:2; )
alert tcp $EXTERNAL_NET any -> $HOME_NET $HTTP_PORTS ( msg:"LOCAL-OFFICIAL-WEBAPP shadow file access attempt"; flow:to_server,established; http_uri; content:"shadow",fast_pattern,nocase; metadata:ruleset local-official-fallback; service:http; classtype:attempted-recon; sid:9901129; rev:2; )
alert tcp $EXTERNAL_NET any -> $HOME_NET $HTTP_PORTS ( msg:"LOCAL-OFFICIAL-APP-DETECT Acunetix web vulnerability scanner probe attempt"; flow:to_server,established; http_uri; content:"/acunetix-wvs-test-for-some-inexistent-file",fast_pattern,nocase; metadata:ruleset local-official-fallback; service:http; classtype:web-application-attack; sid:99025359; rev:2; )
alert tcp $EXTERNAL_NET any -> $HOME_NET $HTTP_PORTS ( msg:"LOCAL-OFFICIAL-SQL SQL union select injection attempt"; flow:to_server,established; http_uri; content:"union",fast_pattern,nocase; content:"select",nocase; pcre:"/union\s+(all\s+)?select\s+/i"; metadata:ruleset local-official-fallback; service:http; classtype:web-application-attack; sid:99013990; rev:2; )
alert tcp $EXTERNAL_NET any -> $HOME_NET $HTTP_PORTS ( msg:"LOCAL-OFFICIAL-WEBAPP script tag cross-site scripting attempt"; flow:to_server,established; http_uri; content:"<script",fast_pattern,nocase; metadata:ruleset local-official-fallback; service:http; classtype:web-application-attack; sid:99007070; rev:2; )
alert tcp $EXTERNAL_NET any -> $HOME_NET $HTTP_PORTS ( msg:"LOCAL-OFFICIAL-WEBAPP environment file disclosure attempt"; flow:to_server,established; http_uri; content:".env",fast_pattern,nocase; metadata:ruleset local-official-fallback; service:http; classtype:web-application-attack; sid:9901126; rev:2; )
alert tcp $EXTERNAL_NET any -> $HOME_NET $HTTP_PORTS ( msg:"LOCAL-OFFICIAL-WEBAPP wp-config disclosure attempt"; flow:to_server,established; http_uri; content:"wp-config.php",fast_pattern,nocase; metadata:ruleset local-official-fallback; service:http; classtype:web-application-attack; sid:9901127; rev:2; )
alert tcp $EXTERNAL_NET any -> $HOME_NET $HTTP_PORTS ( msg:"LOCAL-OFFICIAL-WEBAPP phpMyAdmin probing attempt"; flow:to_server,established; http_uri; content:"phpmyadmin",fast_pattern,nocase; metadata:ruleset local-official-fallback; service:http; classtype:web-application-attack; sid:9901128; rev:2; )
alert tcp $EXTERNAL_NET any -> $HOME_NET $HTTP_PORTS ( msg:"LOCAL-OFFICIAL-WEBAPP Log4Shell JNDI lookup attempt"; flow:to_server,established; http_uri; content:"${jndi:",fast_pattern,nocase; metadata:ruleset local-official-fallback; service:http; classtype:web-application-attack; sid:99044228; rev:2; )
