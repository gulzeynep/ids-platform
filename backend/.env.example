# Optional backend-only fallback for running FastAPI outside Docker.
# Docker Compose uses the root ../.env file as the source of truth.

DATABASE_URL=postgresql+asyncpg://postgres:12345@127.0.0.1:5434/ids_db

API_KEY=secret_api_key_for_ids_engine
SNORT_API_KEY=secret_api_key_for_ids_engine
SECRET_KEY=your_very_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_URL=redis://127.0.0.1:6379/0

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

FRONTEND_URL=http://localhost:5173
